  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0418\u0433\u0440\u043E\u043A \u0441\u043D\u0438\u043C\u0430\u0435\u0442
    \u043A\u0432\u0430\u0440\u0442\u0438\u0440\u0443 \u043D\u0430 \u043E\u043A\u0440\u0430\u0438\u043D\u0435
    \u041C\u043E\u0441\u043A\u0432\u044B \u0438 \u0434\u043E\u043B\u0436\u0435\u043D
    \u043F\u0440\u043E\u0436\u0438\u0442\u044C \u043C\u0435\u0441\u044F\u0446, \u0432\u043E\u0432\u0440\u0435\u043C\u044F
    \u043F\u043B\u0430\u0442\u044F \u0430\u0440\u0435\u043D\u0434\u0443, \u043D\u0435
    \u0441\u0441\u043E\u0440\u044F\u0441\u044C \u0441 \u0434\u0435\u0432\u0443\u0448\u043A\u043E\u0439,
    \u043D\u0435 \u0440\u0430\u0437\u0434\u0440\u0430\u0436\u0430\u044F \u0441\u0442\u0430\u0440\u0443\u0445\u0443-\u0430\u0440\u0435\u043D\u0434\u043E\u0434\u0430\u0442\u0435\u043B\u044C\u043D\u0438\u0446\u0443
    \u0438 \u043F\u043E\u0434\u043A\u0443\u043F\u0430\u044F \u043A\u043E\u0442\u0430-\u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0442\u043E\u0440\u0430
    \u0435\u0434\u043E\u0439.\n\n\u0426\u0435\u043B\u044C \u2014 \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u0442\u044C
    \u0436\u0438\u043B\u044C\u0451, \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0438 \u043E\u0441\u0442\u0430\u0442\u043A\u0438 \u0440\u0430\u0441\u0441\u0443\u0434\u043A\u0430,
    \u043F\u043E\u043A\u0430 \u043A\u0432\u0430\u0440\u0442\u0438\u0440\u0430, \u0441\u043E\u0441\u0435\u0434\u0438
    \u0438 \u0441\u0430\u043C\u0430 \u041A\u0430\u043F\u043E\u0442\u043D\u044F \u043A\u0430\u0436\u0434\u044B\u0439
    \u0434\u0435\u043D\u044C \u043F\u043E\u0434\u043A\u0438\u0434\u044B\u0432\u0430\u044E\u0442
    \u043D\u043E\u0432\u044B\u0435 \u0431\u044B\u0442\u043E\u0432\u044B\u0435 \u043A\u0430\u0442\u0430\u0441\u0442\u0440\u043E\u0444\u044B."
