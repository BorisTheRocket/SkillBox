  m_text: "- \u0421\u0430\u0434\u0438\u0442\u0441\u044F \u043D\u0430\u043F\u0440\u043E\u0442\u0438\u0432,
    \u0441\u043C\u043E\u0442\u0440\u0438\u0442 \u043D\u0435 \u043E\u0442\u0440\u044B\u0432\u0430\u044F\u0441\u044C.
    \u041F\u0435\u0440\u0435\u0434\u0430\u0435\u0442 \u0434\u0430\u043D\u043D\u044B\u0435
    \u043E \u043F\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u0438 \u0430\u0440\u0435\u043D\u0434\u0430\u0442\u043E\u0440\u0430
    \u0417\u0438\u043D\u0430\u0438\u0434\u0435 \u043A\u0430\u0436\u0434\u044B\u0435
    4 \u0438\u0433\u0440\u043E\u0432\u044B\u0445 \u0447\u0430\u0441\u0430 \u0432
    \u0432\u0438\u0434\u0435 \u0441\u043D\u043E\u0432,\n- \u0417\u0430\u043F\u043E\u043C\u0438\u043D\u0430\u0435\u0442
    \u043B\u0438\u0446\u0430 \u0433\u043E\u0441\u0442\u0435\u0439 \u0430\u0440\u0435\u043D\u0434\u0430\u0442\u043E\u0440\u0430\n-
    \u0421\u043F\u043E\u0441\u043E\u0431\u0435\u043D \u043F\u0435\u0440\u0435\u0439\u0442\u0438
    \u043D\u0430 \u0441\u0442\u043E\u0440\u043E\u043D\u0443 \u0438\u0433\u0440\u043E\u043A\u0430.\n\n\n"
